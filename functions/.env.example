# Twilio kimlik bilgileri — Bu değerleri firebase functions:config:set ile ayarlayın
# Aşağıdaki komutu terminalden çalıştırın:
#
# firebase functions:config:set \
#   twilio.sid="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" \
#   twilio.token="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" \
#   twilio.phone="+1xxxxxxxxxx" \
#   twilio.whatsapp="whatsapp:+14155238886"
#
# Twilio bilgilerini nereden alırsınız:
#   - SID ve Token: https://console.twilio.com → Dashboard
#   - Phone Number: https://console.twilio.com → Phone Numbers
#   - WhatsApp Sandbox: https://console.twilio.com → Messaging → Try it out

TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1xxxxxxxxxx
TWILIO_WHATSAPP=whatsapp:+14155238886
